# ── LLM provider (groq | gemini | deepseek) ──────────────────────────────────
LLM_PROVIDER=groq

# ── Groq (default LLM — free at console.groq.com) ───────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=250
GROQ_TEMPERATURE=0.7

# ── DeepSeek (alternative LLM) ───────────────────────────────────────────────
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_MAX_TOKENS=250
# DEEPSEEK_TEMPERATURE=0.7

# ── Google Gemini (alternative LLM) ──────────────────────────────────────────
# GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MAX_TOKENS=250
# GEMINI_TEMPERATURE=0.7

# ── Deepgram (audio transcription — deepgram.com) ────────────────────────────
# Required for audio/voice message transcription.
# Without this key, audio messages are received but not transcribed.
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AI system prompt ─────────────────────────────────────────────────────────
# Optional. If set, overrides the default prompt in src/constants.ts.
# SYSTEM_PROMPT=You are a support agent for Acme Ltd. Always reply in Portuguese, be concise and friendly.

# ── AI draft splitting ───────────────────────────────────────────────────────
# How many parts the AI splits its reply into (1 = single message, default: 3)
# MAX_DRAFT_PARTS=3

# ── Webhook ──────────────────────────────────────────────────────────────────
# Optional URL to forward inbound messages to
# WEBHOOK_URL=https://your-endpoint.com/webhook

# ── PostgreSQL ──────────────────────────────────────────────────────────────────
# SUPABASE_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<ref>.supabase.co:5432/postgres
